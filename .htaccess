# Good Enough Garage Doors — Hostinger (Apache). Clean extensionless URLs, HTTPS +
# canonical host, gzip, smart caching (HTML uncached, assets long+versioned), protect internals.

Options +FollowSymLinks -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ---- Force HTTPS ----
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP:X-Forwarded-Proto} =http
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ---- Canonical host: www -> root domain ----
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # ---- strip index.html (root or subdir) -> directory ----
  RewriteCond %{THE_REQUEST} \s/+(([^?\s]*/)?)index\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # ---- /page.html -> /page/  (301; consolidates old links) ----
  RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
  RewriteRule ^ /%1/ [R=301,L]

  # ---- serve /page/ (or /page) from /page.html ----
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^([^/]+)/?$ $1.html [L]
  # ---- serve /sub/page/ (e.g. /service-areas/vancouver/) from /sub/page.html ----
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^(.+)/$ $1.html [L]

  # ---- block internals ----
  RewriteRule ^(_build|_shared)/ - [F,L]
</IfModule>

# ---- Protect internal / brain files ----
RedirectMatch 404 ^/_shared/
RedirectMatch 404 ^/_build/
RedirectMatch 404 ^/\.leads\.log
<FilesMatch "\.(md|mjs|sh|gitmodules|log)$">
  Require all denied
</FilesMatch>
# Block JSON except the public web manifest + site-config is not served anyway
<FilesMatch "\.json$">
  Require all denied
</FilesMatch>
<Files "site.webmanifest">
  Require all granted
</Files>

# ---- Correct MIME for modern formats ----
AddType image/avif .avif
AddType font/woff2 .woff2

# ---- Compression: Brotli if available, else gzip ----
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript image/svg+xml application/json
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/json application/x-php
</IfModule>

# ---- Caching: HTML must revalidate; static assets long + immutable (we version with ?v=) ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/avif        "access plus 1 year"
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType font/woff2        "access plus 1 year"
  ExpiresByType text/css          "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/html         "access plus 0 seconds"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(avif|webp|jpg|jpeg|png|svg|woff2|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

ErrorDocument 404 /404.html
